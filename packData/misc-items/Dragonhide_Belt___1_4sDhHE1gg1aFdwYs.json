        "command": "if (args[0].tag !== \"OnUse\" || args[0].macroPass !== \"preSave\") {\n  return;\n}\n\nif (rolledItem?.system.type.value !== \"class\" || rolledItem?.system.type.subtype !== \"ki\") {\n  return;\n}\nif (!workflow.hasSave || !workflow.saveActivity?.save?.dc) {\n  return;\n}\nconst save = workflow.saveActivity.save;\nconst dragonHideBeltDCBonus = actor.getFlag(\"dae\", \"dragonHideBeltDCBonus\") ?? \"\";\nsave.dc.bonus ??= \"\";\nsave.dc.bonus += dragonHideBeltDCBonus;\nconst rollData = actor.getRollData({ deterministic: true });\nconst bonus = dnd5e.utils.simplifyBonus(dragonHideBeltDCBonus, rollData);\nsave.dc.value += bonus;",
