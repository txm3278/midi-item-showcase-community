    "dae": {
      "macro": {
        "name": "Bloodwell Vial, +1",
        "img": "icons/tools/laboratory/vial-orange.webp",
        "type": "script",
        "scope": "global",
        "command": "if (args[0].tag !== \"OnUse\" || args[0].macroPass !== \"preSave\") {\n    return;\n}\nif (rolledItem.type !== \"spell\" || rolledItem.system.sourceClass !== \"sorcerer\") {\n  return;\n}\nif (!workflow.hasSave || !workflow.saveActivity?.save?.dc) {\n  return;\n}\nconst save = workflow.saveActivity.save;\nconst bloodwellVialBonus = actor.getFlag(\"dae\", \"bloodwellVialBonus\") ?? \"\";\nsave.dc.bonus ??= \"\";\nsave.dc.bonus += bloodwellVialBonus;\nconst rollData = actor.getRollData({ deterministic: true });\nconst bonus = dnd5e.utils.simplifyBonus(bloodwellVialBonus, rollData);\nsave.dc.value += bonus;",
        "author": "9QqTZMFq1dhCIYAR",
        "ownership": {
          "default": 3
        },
